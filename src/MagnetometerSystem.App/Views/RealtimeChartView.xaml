<UserControl x:Class="MagnetometerSystem.App.Views.RealtimeChartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1100"
             Loaded="OnLoaded">
    <UserControl.Resources>
        <!-- 预设颜色列表 -->
        <x:Array x:Key="PresetColors" Type="{x:Type sys:String}">
            <sys:String>#FF0000FF</sys:String>
            <sys:String>#FFFF0000</sys:String>
            <sys:String>#FF008000</sys:String>
            <sys:String>#FFFF8C00</sys:String>
            <sys:String>#FF800080</sys:String>
            <sys:String>#FF00FFFF</sys:String>
            <sys:String>#FFFF00FF</sys:String>
            <sys:String>#FFB8860B</sys:String>
            <sys:String>#FF000000</sys:String>
            <sys:String>#FF808080</sys:String>
        </x:Array>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧主区域 -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 工具栏 -->
            <WrapPanel Grid.Row="0" Margin="0,0,0,8">
                <Button Padding="10,5" Margin="0,0,8,0" Command="{Binding TogglePauseCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Content" Value="暂停"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                    <Setter Property="Content" Value="继续"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="清空" Padding="10,5" Margin="0,0,15,0"
                        Command="{Binding ClearChartCommand}"/>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,2,15,2"/>

                <TextBlock Text="时间窗口:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox Width="80" ItemsSource="{Binding TimeWindowOptions}"
                          SelectedItem="{Binding TimeWindowSeconds}" IsEditable="True"/>
                <TextBlock Text="s" VerticalAlignment="Center" Margin="3,0,15,0"/>

                <CheckBox Content="Y轴自适应" VerticalAlignment="Center" Margin="0,0,10,0"
                          IsChecked="{Binding AutoScaleY}"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AutoScaleY}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Y:" VerticalAlignment="Center" Margin="0,0,3,0"/>
                    <TextBox Width="70" Text="{Binding YMin, UpdateSourceTrigger=LostFocus}" VerticalAlignment="Center"/>
                    <TextBlock Text="~" VerticalAlignment="Center" Margin="3,0,3,0"/>
                    <TextBox Width="70" Text="{Binding YMax, UpdateSourceTrigger=LostFocus}" VerticalAlignment="Center"/>
                </StackPanel>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,2,15,2"/>

                <CheckBox Content="自动滚动" VerticalAlignment="Center" Margin="0,0,10,0"
                          IsChecked="{Binding AutoScroll}"/>
                <CheckBox Content="网格" VerticalAlignment="Center" Margin="0,0,10,0"
                          IsChecked="{Binding ShowGrid}"/>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,2,15,2"/>

                <Button Padding="10,5" Margin="0,0,8,0" Command="{Binding ToggleMultiPlotModeCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Content" Value="多图表"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMultiPlotMode}" Value="True">
                                    <Setter Property="Content" Value="单图表"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,2,15,2"/>

                <TextBlock Text="刷新率:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <Slider Width="80" Minimum="5" Maximum="60" Value="{Binding RefreshRate}"
                        VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="5"/>
                <TextBlock VerticalAlignment="Center" Margin="5,0,0,0">
                    <Run Text="{Binding RefreshRate, Mode=OneWay}"/>
                    <Run Text="fps"/>
                </TextBlock>
            </WrapPanel>

            <!-- ScottPlot 图表区 -->
            <Grid Grid.Row="1">
                <Border BorderBrush="#CCC" BorderThickness="1" x:Name="SinglePlotBorder">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMultiPlotMode}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <scottplot:WpfPlot x:Name="WpfPlot1" MouseWheel="OnPlotMouseWheel"/>
                </Border>

                <Border BorderBrush="#CCC" BorderThickness="1" x:Name="MultiPlotBorder">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMultiPlotMode}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="MultiPlotPanel"/>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- 底部统计栏 -->
            <Border Grid.Row="2" Margin="0,5,0,0" Padding="8,4" Background="#F8F8F8" CornerRadius="3">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Margin="10,0,0,0">
                        <Run Text="数据点: "/>
                        <Run Text="{Binding DataPointCount, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding StatisticsText}" VerticalAlignment="Center"
                               FontFamily="Consolas" FontSize="11.5" TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </Border>
        </Grid>

        <!-- 右侧配置面板 -->
        <Border Grid.Column="1" Width="260" Margin="8,0,0,0" Background="#FAFAFA"
                BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="3" Padding="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- ======== 通道设置 ======== -->
                    <Expander Header="通道设置" IsExpanded="True" Margin="0,0,0,6">
                        <StackPanel Margin="0,4,0,0">
                            <ItemsControl ItemsSource="{Binding ChannelConfigs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="2,3" Margin="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <CheckBox Grid.Column="0" Grid.Row="0"
                                                          IsChecked="{Binding Visible}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                               FontWeight="SemiBold" Width="40"/>
                                                    <ComboBox Width="50" Height="20" Margin="4,0,0,0"
                                                              ItemsSource="{StaticResource PresetColors}"
                                                              SelectedItem="{Binding ColorHex}"
                                                              VerticalAlignment="Center">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Width="30" Height="12" CornerRadius="2">
                                                                    <Border.Background>
                                                                        <SolidColorBrush Color="{Binding}"/>
                                                                    </Border.Background>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                </StackPanel>

                                                <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                                                            Orientation="Horizontal" Margin="20,2,0,0">
                                                    <TextBlock Text="偏移:" VerticalAlignment="Center" FontSize="11" Margin="0,0,3,0"/>
                                                    <TextBox Width="65" FontSize="11" VerticalAlignment="Center"
                                                             Text="{Binding DisplayOffset, UpdateSourceTrigger=LostFocus}"/>
                                                    <TextBlock Text="nT" VerticalAlignment="Center" FontSize="11" Margin="3,0,3,0" Foreground="Gray"/>
                                                    <Button Content="自动" FontSize="10" Padding="4,1" VerticalAlignment="Center"
                                                            ToolTip="根据通道平均值自动设置偏移，使数据趋近于 0"
                                                            Command="{Binding DataContext.AutoOffsetChannelCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding ChannelIndex}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Expander>

                    <!-- ======== 计算通道 ======== -->
                    <Expander Header="计算通道" IsExpanded="True" Margin="0,0,0,6">
                        <StackPanel Margin="0,4,0,0">
                            <!-- 已有计算通道列表 -->
                            <ItemsControl ItemsSource="{Binding ComputedChannels}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="2,3" Margin="0,0,0,2">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <CheckBox IsChecked="{Binding Enabled}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBox Width="50" FontSize="11" Text="{Binding Name, UpdateSourceTrigger=LostFocus}"
                                                             VerticalAlignment="Center"/>
                                                    <ComboBox Width="40" Height="20" Margin="4,0,0,0"
                                                              ItemsSource="{StaticResource PresetColors}"
                                                              SelectedItem="{Binding ColorHex}"
                                                              VerticalAlignment="Center">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Width="24" Height="12" CornerRadius="2">
                                                                    <Border.Background>
                                                                        <SolidColorBrush Color="{Binding}"/>
                                                                    </Border.Background>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                    <Button Content="×" FontSize="11" Padding="4,0" Margin="4,0,0,0"
                                                            VerticalAlignment="Center"
                                                            Command="{Binding DataContext.RemoveComputedChannelCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                                <TextBox FontSize="11" Margin="20,2,0,0"
                                                         Text="{Binding Formula, UpdateSourceTrigger=LostFocus}"
                                                         ToolTip="公式: CH0~CH7, +,-,*,/, sqrt(), abs(), pow()"/>
                                                <!-- 偏移 + 自动偏移 -->
                                                <StackPanel Orientation="Horizontal" Margin="20,2,0,0">
                                                    <TextBlock Text="偏移:" VerticalAlignment="Center" FontSize="11" Margin="0,0,3,0"/>
                                                    <TextBox Width="65" FontSize="11" VerticalAlignment="Center"
                                                             Text="{Binding DisplayOffset, UpdateSourceTrigger=LostFocus}"/>
                                                    <TextBlock Text="nT" VerticalAlignment="Center" FontSize="11" Margin="3,0,3,0" Foreground="Gray"/>
                                                    <Button Content="自动" FontSize="10" Padding="4,1" VerticalAlignment="Center"
                                                            ToolTip="根据计算通道平均值自动设置偏移，使数据趋近于 0"
                                                            Command="{Binding DataContext.AutoOffsetComputedChannelCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- 添加按钮行 -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Button Content="+ 总场" FontSize="11" Padding="6,2" Margin="0,0,4,0"
                                        HorizontalAlignment="Left"
                                        ToolTip="选择三个通道计算总场 sqrt(a²+b²+c²)"
                                        Command="{Binding StartAddTotalFieldCommand}"/>
                                <Button Content="+ 梯度" FontSize="11" Padding="6,2" Margin="0,0,4,0"
                                        HorizontalAlignment="Left"
                                        ToolTip="选择两个源做差值 a - b"
                                        Command="{Binding StartAddGradientCommand}"/>
                                <Button Content="+ 自定义" FontSize="11" Padding="6,2"
                                        HorizontalAlignment="Left"
                                        ToolTip="自由输入公式"
                                        Command="{Binding AddComputedChannelCommand}"/>
                            </StackPanel>

                            <!-- ======== 总场向导面板 ======== -->
                            <Border Margin="0,4,0,0" Padding="6" Background="#F0F0F0" CornerRadius="3"
                                    BorderBrush="#CCC" BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAddingTotalField}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="选择三个通道:" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                        <TextBlock Text="A:" FontSize="11" VerticalAlignment="Center" Width="16"/>
                                        <ComboBox Width="120" FontSize="11"
                                                  ItemsSource="{Binding WizardRawSources}"
                                                  SelectedIndex="{Binding WizardSourceA}"
                                                  DisplayMemberPath="Label"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                        <TextBlock Text="B:" FontSize="11" VerticalAlignment="Center" Width="16"/>
                                        <ComboBox Width="120" FontSize="11"
                                                  ItemsSource="{Binding WizardRawSources}"
                                                  SelectedIndex="{Binding WizardSourceB}"
                                                  DisplayMemberPath="Label"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="C:" FontSize="11" VerticalAlignment="Center" Width="16"/>
                                        <ComboBox Width="120" FontSize="11"
                                                  ItemsSource="{Binding WizardRawSources}"
                                                  SelectedIndex="{Binding WizardSourceC}"
                                                  DisplayMemberPath="Label"/>
                                    </StackPanel>
                                    <TextBlock Text="公式: sqrt(A²+B²+C²)" FontSize="10" Foreground="Gray" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="确认" FontSize="11" Padding="8,2" Margin="0,0,6,0"
                                                Command="{Binding ConfirmAddTotalFieldCommand}"/>
                                        <Button Content="取消" FontSize="11" Padding="8,2"
                                                Command="{Binding CancelAddWizardCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- ======== 梯度向导面板 ======== -->
                            <Border Margin="0,4,0,0" Padding="6" Background="#F0F0F0" CornerRadius="3"
                                    BorderBrush="#CCC" BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAddingGradient}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="选择两个源 (A - B):" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                        <TextBlock Text="A:" FontSize="11" VerticalAlignment="Center" Width="16"/>
                                        <ComboBox Width="140" FontSize="11"
                                                  ItemsSource="{Binding WizardGradientSources}"
                                                  SelectedIndex="{Binding WizardSourceA}"
                                                  DisplayMemberPath="Label"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="B:" FontSize="11" VerticalAlignment="Center" Width="16"/>
                                        <ComboBox Width="140" FontSize="11"
                                                  ItemsSource="{Binding WizardGradientSources}"
                                                  SelectedIndex="{Binding WizardSourceB}"
                                                  DisplayMemberPath="Label"/>
                                    </StackPanel>
                                    <TextBlock Text="公式: A - B" FontSize="10" Foreground="Gray" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="确认" FontSize="11" Padding="8,2" Margin="0,0,6,0"
                                                Command="{Binding ConfirmAddGradientCommand}"/>
                                        <Button Content="取消" FontSize="11" Padding="8,2"
                                                Command="{Binding CancelAddWizardCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="变量: CH0~CH7" FontSize="10" Foreground="Gray" Margin="0,6,0,0"/>
                            <TextBlock Text="运算: + - * / sqrt abs pow" FontSize="10" Foreground="Gray"/>
                        </StackPanel>
                    </Expander>

                    <!-- ======== 统计配置 ======== -->
                    <Expander Header="统计设置" IsExpanded="False" Margin="0,0,0,6">
                        <StackPanel Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="窗口:" VerticalAlignment="Center" FontSize="11" Margin="0,0,3,0"/>
                                <TextBox Width="50" FontSize="11"
                                         Text="{Binding StatisticsConfig.WindowSeconds, UpdateSourceTrigger=LostFocus}"/>
                                <TextBlock Text="s" VerticalAlignment="Center" FontSize="11" Margin="3,0,0,0" Foreground="Gray"/>
                            </StackPanel>
                            <CheckBox Content="均值 (Avg)" FontSize="11" Margin="0,1"
                                      IsChecked="{Binding StatisticsConfig.ShowMean}"/>
                            <CheckBox Content="标准差 (Std)" FontSize="11" Margin="0,1"
                                      IsChecked="{Binding StatisticsConfig.ShowStdDev}"/>
                            <CheckBox Content="峰峰值 (PP)" FontSize="11" Margin="0,1"
                                      IsChecked="{Binding StatisticsConfig.ShowPeakToPeak}"/>
                            <CheckBox Content="均方根 (RMS)" FontSize="11" Margin="0,1"
                                      IsChecked="{Binding StatisticsConfig.ShowRms}"/>
                            <CheckBox Content="最小值 (Min)" FontSize="11" Margin="0,1"
                                      IsChecked="{Binding StatisticsConfig.ShowMin}"/>
                            <CheckBox Content="最大值 (Max)" FontSize="11" Margin="0,1"
                                      IsChecked="{Binding StatisticsConfig.ShowMax}"/>
                        </StackPanel>
                    </Expander>

                    <!-- ======== 正交度校正 ======== -->
                    <Expander Header="正交度校正" IsExpanded="False" Margin="0,0,0,6">
                        <StackPanel Margin="0,4,0,0">
                            <CheckBox Content="启用正交度校正" FontSize="11" Margin="0,2"
                                      IsChecked="{Binding DataContext.ConnectionVM.IsOrthogonalityCorrectionEnabled,
                                      RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <TextBlock Text="校正在数据源端进行，" FontSize="10" Foreground="Gray" Margin="0,4,0,0"/>
                            <TextBlock Text="需先加载校正配置。" FontSize="10" Foreground="Gray" Margin="0,0,0,0"/>
                        </StackPanel>
                    </Expander>

                    <TextBlock Text="滚轮: 缩放时间轴" FontSize="10" Foreground="Gray" Margin="0,4,0,0"/>
                    <TextBlock Text="Ctrl+滚轮: 缩放Y轴" FontSize="10" Foreground="Gray" Margin="0,2,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
