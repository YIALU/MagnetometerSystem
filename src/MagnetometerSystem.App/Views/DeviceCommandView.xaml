<UserControl x:Class="MagnetometerSystem.App.Views.DeviceCommandView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="B2V"/>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶栏：命令组切换 + 导入导出 + 状态 -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="命令组:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding Groups}"
                      DisplayMemberPath="Name"
                      SelectedItem="{Binding SelectedGroup}"
                      Padding="4"/>
            <Button Grid.Column="2" Content="+组" Padding="8,4" Margin="6,0,0,0"
                    Command="{Binding AddGroupCommand}"/>
            <Button Grid.Column="3" Content="改名" Padding="8,4" Margin="3,0,0,0"
                    Command="{Binding RenameGroupCommand}"
                    IsEnabled="{Binding SelectedGroup, Converter={StaticResource B2V}}"/>
            <Button Grid.Column="4" Content="删组" Padding="8,4" Margin="3,0,12,0"
                    Command="{Binding DeleteGroupCommand}"
                    IsEnabled="{Binding SelectedGroup, Converter={StaticResource B2V}}"/>
            <Button Grid.Column="5" Content="导入Catalog" Padding="8,4" Margin="0,0,4,0"
                    Command="{Binding ImportCatalogCommand}"/>
            <Button Grid.Column="6" Content="导出Catalog" Padding="8,4" HorizontalAlignment="Left"
                    Command="{Binding ExportCatalogCommand}"/>
            <TextBlock Grid.Column="7" VerticalAlignment="Center">
                <Run Text="状态: "/>
                <Run>
                    <Run.Style>
                        <Style TargetType="Run">
                            <Setter Property="Text" Value="● 未连接"/>
                            <Setter Property="Foreground" Value="Gray"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Text" Value="● 已连接"/>
                                    <Setter Property="Foreground" Value="Green"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Run.Style>
                </Run>
            </TextBlock>
        </Grid>

        <!-- 主区：左命令列表 + 右详情 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左：命令列表 -->
            <GroupBox Grid.Column="0" Header="命令列表" Padding="4">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,4,0,0">
                        <Button Content="+新建" Padding="8,3"
                                Command="{Binding AddCommandCommand}"/>
                        <Button Content="编辑" Padding="8,3" Margin="4,0,0,0"
                                Command="{Binding EditCommandCommand}"
                                CommandParameter="{Binding SelectedCommand}"/>
                        <Button Content="删除" Padding="8,3" Margin="4,0,0,0"
                                Command="{Binding DeleteCommandCommand}"
                                CommandParameter="{Binding SelectedCommand}"/>
                    </StackPanel>
                    <ListBox ItemsSource="{Binding CurrentCommands}"
                             SelectedItem="{Binding SelectedCommand}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Description}"
                                               Foreground="Gray" FontSize="11"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </GroupBox>

            <!-- 右：命令详情 -->
            <GroupBox Grid.Column="1" Header="命令详情" Padding="8" Margin="6,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 名称 -->
                    <TextBlock Grid.Row="0" FontSize="16" FontWeight="Bold"
                               Text="{Binding SelectedCommand.Name, FallbackValue='（请选择命令）'}"/>
                    <!-- 描述 -->
                    <TextBlock Grid.Row="1" Foreground="#555" Margin="0,4,0,8"
                               TextWrapping="Wrap"
                               Text="{Binding SelectedCommand.Description}"/>
                    <!-- 模板 -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="模板:" FontWeight="SemiBold" Margin="0,0,6,0"/>
                        <TextBlock FontFamily="Consolas" Foreground="#08538A"
                                   Text="{Binding SelectedCommand.Template}"/>
                    </StackPanel>

                    <!-- 参数表单 -->
                    <GroupBox Grid.Row="3" Header="参数" Padding="6">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding CurrentParameters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="160"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock VerticalAlignment="Center">
                                                <Run Text="{Binding Definition.Name, Mode=OneWay}"/>
                                                <Run Text=":"/>
                                            </TextBlock>
                                            <TextBox Grid.Column="1" Padding="4"
                                                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"/>
                                            <TextBlock Grid.Column="2" Margin="6,0,0,0"
                                                       VerticalAlignment="Center" Foreground="Gray"
                                                       Text="{Binding Definition.Unit, Mode=OneWay}"/>
                                            <TextBlock Grid.Column="3" Margin="6,0,0,0"
                                                       VerticalAlignment="Center" Foreground="Gray"
                                                       FontSize="11">
                                                <Run Text="范围: "/>
                                                <Run Text="{Binding Definition.Min, Mode=OneWay, FallbackValue='—'}"/>
                                                <Run Text=" ~ "/>
                                                <Run Text="{Binding Definition.Max, Mode=OneWay, FallbackValue='—'}"/>
                                            </TextBlock>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </GroupBox>

                    <!-- 预览 -->
                    <Grid Grid.Row="4" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="预览:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Background="#F4F6F8" Padding="6" CornerRadius="3">
                            <TextBox FontFamily="Consolas" Foreground="#222"
                                     Text="{Binding PreviewText, Mode=OneWay}"
                                     TextWrapping="Wrap"
                                     IsReadOnly="True"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="60"/>
                        </Border>
                    </Grid>

                    <!-- 发送 -->
                    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="发送"
                                Padding="20,6"
                                FontWeight="Bold"
                                Background="#0078D4" Foreground="White"
                                Command="{Binding SendSelectedCommandCommand}"
                                IsEnabled="{Binding IsConnected}"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- 通信日志 -->
        <GroupBox Grid.Row="2" Margin="0,8,0,0" Padding="4">
            <GroupBox.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="通信日志" VerticalAlignment="Center"/>
                    <CheckBox Grid.Column="1" Content="暂停滚动" Margin="8,0"
                              IsChecked="{Binding PauseAutoScroll}"/>
                    <Button Grid.Column="2" Content="清空" Padding="6,2"
                            Command="{Binding ClearLogCommand}"/>
                </Grid>
            </GroupBox.Header>
            <ScrollViewer x:Name="LogScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                <TextBox Text="{Binding CommunicationLog, Mode=OneWay}"
                         IsReadOnly="True"
                         FontFamily="Consolas" FontSize="12"
                         TextWrapping="NoWrap"
                         Background="#1E1E1E" Foreground="#D4D4D4"
                         BorderThickness="0"
                         x:Name="LogTextBox"/>
            </ScrollViewer>
        </GroupBox>

        <!-- 自由发送（折叠） -->
        <Expander Grid.Row="3" Header="自由发送（手动输入命令）" Margin="0,6,0,0"
                  IsExpanded="{Binding ShowFreeSend}">
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" FontFamily="Consolas" Padding="4"
                         Text="{Binding FreeCommandText, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SendFreeCommandCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <CheckBox Grid.Column="1" Content="Hex"
                          IsChecked="{Binding FreeIsHexMode}"
                          VerticalAlignment="Center" Margin="8,0"/>
                <CheckBox Grid.Column="2" Content="换行"
                          IsChecked="{Binding FreeAppendNewline}"
                          VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button Grid.Column="3" Content="发送"
                        Padding="14,4"
                        Command="{Binding SendFreeCommandCommand}"
                        IsEnabled="{Binding IsConnected}"/>
            </Grid>
        </Expander>
    </Grid>
</UserControl>
