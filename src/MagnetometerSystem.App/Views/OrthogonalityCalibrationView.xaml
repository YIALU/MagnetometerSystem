<UserControl x:Class="MagnetometerSystem.App.Views.OrthogonalityCalibrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:MagnetometerSystem.App.Views"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">

    <DockPanel Margin="10">

        <!-- 顶部步骤指示器 (4 步) -->
        <Border DockPanel.Dock="Top" Background="#F5F5F5" CornerRadius="4" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Margin="10,0" FontSize="13">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="Gray"/>
                            <Setter Property="Text" Value="1. 选择传感器"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="1">
                                    <Setter Property="Foreground" Value="#0078D7"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text=">" VerticalAlignment="Center" Foreground="Gray" Margin="5,0"/>
                <TextBlock Margin="10,0" FontSize="13">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="Gray"/>
                            <Setter Property="Text" Value="2. 采集数据"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="2">
                                    <Setter Property="Foreground" Value="#0078D7"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text=">" VerticalAlignment="Center" Foreground="Gray" Margin="5,0"/>
                <TextBlock Margin="10,0" FontSize="13">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="Gray"/>
                            <Setter Property="Text" Value="3. 计算与结果"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="3">
                                    <Setter Property="Foreground" Value="#0078D7"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text=">" VerticalAlignment="Center" Foreground="Gray" Margin="5,0"/>
                <TextBlock Margin="10,0" FontSize="13">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="Gray"/>
                            <Setter Property="Text" Value="4. 保存配置"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="4">
                                    <Setter Property="Foreground" Value="#0078D7"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- 底部导航按钮 -->
        <Border DockPanel.Dock="Bottom" Padding="10" Margin="0,10,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Foreground="Gray">
                    <Run Text="步骤 "/>
                    <Run Text="{Binding CurrentStep, Mode=OneWay}"/>
                    <Run Text=" / 4"/>
                </TextBlock>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="上一步" Padding="15,6" Margin="0,0,8,0"
                            Command="{Binding PreviousStepCommand}"
                            IsEnabled="{Binding CanGoBack}"/>
                    <Button Content="下一步" Padding="15,6"
                            Command="{Binding NextStepCommand}"
                            IsEnabled="{Binding CanGoNext}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 步骤内容区域 -->
        <Grid>
            <!-- ==================== Step 1: 选择传感器 ==================== -->
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="1">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
                    <TextBlock Text="选择传感器" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                    <TextBlock Text="请选择传感器类型并输入序列号（可选）。" Foreground="Gray" Margin="0,0,0,20"/>

                    <TextBlock Text="传感器类型" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding AvailableSensorTypes}"
                              SelectedItem="{Binding SelectedSensorType}"
                              Margin="0,0,0,15" Padding="5,4"/>

                    <TextBlock Text="传感器序列号（可选）" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding SensorSerial, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,15" Padding="5,4"/>

                    <TextBlock Text="参考场强 (nT)（可选）" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding ReferenceFieldStrength, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                             Margin="0,0,0,5" Padding="5,4"/>
                    <TextBlock Text="留空则自动估算（当地地磁场约 50000 nT）" Foreground="Gray" FontSize="11" Margin="0,0,0,15"/>
                </StackPanel>
            </Grid>

            <!-- ==================== Step 2: 采集/导入数据 ==================== -->
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="2">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="450">
                    <TextBlock Text="采集校正数据" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Text="方式一：实时采集 — 缓慢旋转传感器覆盖尽可能多的方位。&#x0a;方式二：导入文件 — 从 CSV/TXT 文件导入已有的三轴数据（Bx,By,Bz）。"
                               Foreground="Gray" TextWrapping="Wrap" Margin="0,0,0,15"/>

                    <!-- 控制按钮 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="开始采集" Padding="15,6" Margin="0,0,8,0"
                                Command="{Binding StartCollectingCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCollecting}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="停止采集" Padding="15,6" Margin="0,0,8,0"
                                Command="{Binding StopCollectingCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="IsEnabled" Value="False"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCollecting}" Value="True">
                                            <Setter Property="IsEnabled" Value="True"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Rectangle Width="1" Fill="#DDD" Margin="4,2"/>
                        <Button Content="导入文件..." Padding="15,6" Margin="8,0,0,0"
                                Command="{Binding ImportFromFileCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCollecting}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="格式说明" Padding="10,6" Margin="4,0,0,0"
                                ToolTip="查看支持的 CSV 格式与示例"
                                Command="{Binding ShowCsvFormatHelpCommand}"/>
                        <Button Content="从已采集会话导入" Padding="10,6" Margin="4,0,0,0"
                                ToolTip="直接从数据库选择一个会话作为校准输入"
                                Command="{Binding LoadFromSessionCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCollecting}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- 采集状态 -->
                    <Border Background="#F9F9F9" CornerRadius="4" Padding="15" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="状态：" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CollectionStatus}" TextWrapping="Wrap" Margin="0,2"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="样本数量：" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,2">
                                <Run Text="{Binding CollectedSampleCount, Mode=OneWay}"/>
                                <Run Text=" 个"/>
                            </TextBlock>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="球面覆盖度：" FontWeight="SemiBold" Margin="0,2"/>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,2">
                                <ProgressBar Width="150" Height="16" Minimum="0" Maximum="100"
                                             Value="{Binding SphericityCoverage, Mode=OneWay}" Margin="0,0,8,0"/>
                                <TextBlock>
                                    <Run Text="{Binding SphericityCoverage, Mode=OneWay, StringFormat={}{0:F1}}"/>
                                    <Run Text="%"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 数据质量提示 -->
                    <Border CornerRadius="4" Padding="15" Margin="0,0,0,10"
                            Background="#FFFDE7" BorderBrush="#F9A825" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasValidationWarnings}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="数据质量提示" FontWeight="SemiBold" Foreground="#F57F17" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding ValidationStatusText}" TextWrapping="Wrap" FontSize="12"/>
                            <TextBlock Text="以上为建议信息，不影响后续计算。" Foreground="Gray" FontSize="11" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 校验统计信息 -->
                    <Border Background="#F9F9F9" CornerRadius="4" Padding="15" Margin="0,0,0,10">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasValidationWarnings}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="总场均值：" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,2">
                                <Run Text="{Binding DataValidation.MeanTotalField, Mode=OneWay, StringFormat={}{0:F0}}"/>
                                <Run Text=" nT"/>
                            </TextBlock>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="总场标准差：" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,2">
                                <Run Text="{Binding DataValidation.TotalFieldStdDev, Mode=OneWay, StringFormat={}{0:F1}}"/>
                                <Run Text=" nT"/>
                            </TextBlock>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="变异系数：" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,2"
                                       Text="{Binding DataValidation.TotalFieldCoeffOfVariation, Mode=OneWay, StringFormat={}{0:P2}}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="突变点数：" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,2">
                                <Run Text="{Binding DataValidation.RejectedCount, Mode=OneWay}"/>
                                <Run Text=" 个"/>
                            </TextBlock>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ==================== Step 3: 计算与结果 (合并) ==================== -->
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="3">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel Width="500" HorizontalAlignment="Center">
                        <TextBlock Text="计算与结果" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="基于采集的数据计算正交度补偿矩阵和偏移向量，计算完成后结果将显示在下方。"
                                   Foreground="Gray" TextWrapping="Wrap" Margin="0,0,0,15"/>

                        <!-- 计算按钮和状态 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="执行计算" Padding="20,8" Margin="0,0,15,0"
                                    Command="{Binding RunCalculationCommand}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCalculating}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <TextBlock Text="{Binding CalculationStatus}" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>

                        <!-- 进度条 -->
                        <ProgressBar Height="4" Margin="0,0,0,15" IsIndeterminate="{Binding IsCalculating}">
                            <ProgressBar.Style>
                                <Style TargetType="ProgressBar">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCalculating}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ProgressBar.Style>
                        </ProgressBar>

                        <!-- ===== 计算结果区域（计算完成后显示） ===== -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CalculationResult.Success}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <!-- 质量评级 -->
                            <Border Background="#E8F5E9" CornerRadius="4" Padding="12" Margin="0,0,0,15">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="质量评级：" FontWeight="SemiBold" FontSize="14"/>
                                    <TextBlock Text="{Binding QualityRating}" FontSize="14" FontWeight="Bold" Foreground="#2E7D32"/>
                                </StackPanel>
                            </Border>

                            <!-- 补偿矩阵 3x3 -->
                            <TextBlock Text="补偿矩阵 (3x3)" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                            <Border Background="#F5F5F5" CornerRadius="4" Padding="10" Margin="0,0,0,15">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding MatrixM00}" HorizontalAlignment="Center" Margin="5,3" FontFamily="Consolas"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding MatrixM01}" HorizontalAlignment="Center" Margin="5,3" FontFamily="Consolas"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding MatrixM02}" HorizontalAlignment="Center" Margin="5,3" FontFamily="Consolas"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding MatrixM10}" HorizontalAlignment="Center" Margin="5,3" FontFamily="Consolas"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MatrixM11}" HorizontalAlignment="Center" Margin="5,3" FontFamily="Consolas"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding MatrixM12}" HorizontalAlignment="Center" Margin="5,3" FontFamily="Consolas"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding MatrixM20}" HorizontalAlignment="Center" Margin="5,3" FontFamily="Consolas"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding MatrixM21}" HorizontalAlignment="Center" Margin="5,3" FontFamily="Consolas"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding MatrixM22}" HorizontalAlignment="Center" Margin="5,3" FontFamily="Consolas"/>
                                </Grid>
                            </Border>

                            <!-- 偏移向量 -->
                            <TextBlock Text="偏移向量" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                            <Border Background="#F5F5F5" CornerRadius="4" Padding="10" Margin="0,0,0,15">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Margin="10,0" FontFamily="Consolas">
                                        <Run Text="X: "/><Run Text="{Binding OffsetX, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Margin="10,0" FontFamily="Consolas">
                                        <Run Text="Y: "/><Run Text="{Binding OffsetY, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Margin="10,0" FontFamily="Consolas">
                                        <Run Text="Z: "/><Run Text="{Binding OffsetZ, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- 残差统计 -->
                            <TextBlock Text="残差统计" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                            <Border Background="#F5F5F5" CornerRadius="4" Padding="10" Margin="0,0,0,15">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="残差均值：" Margin="0,2"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,2">
                                        <Run Text="{Binding CalculationResult.Quality.ResidualMean, Mode=OneWay, StringFormat={}{0:F4}}"/>
                                        <Run Text=" nT"/>
                                    </TextBlock>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="残差标准差：" Margin="0,2"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,2">
                                        <Run Text="{Binding CalculationResult.Quality.ResidualStd, Mode=OneWay, StringFormat={}{0:F4}}"/>
                                        <Run Text=" nT"/>
                                    </TextBlock>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="最大残差：" Margin="0,2"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,2">
                                        <Run Text="{Binding CalculationResult.Quality.MaxResidual, Mode=OneWay, StringFormat={}{0:F4}}"/>
                                        <Run Text=" nT"/>
                                    </TextBlock>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="球面覆盖度：" Margin="0,2"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,2">
                                        <Run Text="{Binding CalculationResult.Quality.SphericityCoverage, Mode=OneWay, StringFormat={}{0:P1}}"/>
                                    </TextBlock>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="样本数量：" Margin="0,2"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CalculationResult.Quality.SampleCount, Mode=OneWay}" Margin="0,2"/>
                                </Grid>
                            </Border>

                            <!-- 校正效果可视化 -->
                            <TextBlock Text="校正效果可视化" FontWeight="SemiBold" FontSize="14" Margin="0,10,0,8"/>
                            <views:CalibrationVisualizationControl
                                RawData="{Binding VisualizationRawData}"
                                CorrectedData="{Binding VisualizationCorrectedData}"
                                Height="400"/>

                            <!-- 第二组三轴校正结果（仅 DualTriaxial） -->
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSensorType}" Value="DualTriaxialFluxgate">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Text="第二组三轴校正结果" FontSize="16" FontWeight="Bold" Margin="0,20,0,10"/>

                                <!-- 第二组质量评级 -->
                                <Border Background="#E8F5E9" CornerRadius="4" Padding="12" Margin="0,0,0,15">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="质量评级：" FontWeight="SemiBold" FontSize="14"/>
                                        <TextBlock Text="{Binding SecondQualityRating}" FontSize="14" FontWeight="Bold" Foreground="#2E7D32"/>
                                    </StackPanel>
                                </Border>

                                <!-- 第二组补偿矩阵 3x3 -->
                                <TextBlock Text="补偿矩阵 (3x3)" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                                <Border Background="#F5F5F5" CornerRadius="4" Padding="10" Margin="0,0,0,15">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding SecondMatrixM00}" HorizontalAlignment="Center" Margin="5,3" FontFamily="Consolas"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SecondMatrixM01}" HorizontalAlignment="Center" Margin="5,3" FontFamily="Consolas"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding SecondMatrixM02}" HorizontalAlignment="Center" Margin="5,3" FontFamily="Consolas"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding SecondMatrixM10}" HorizontalAlignment="Center" Margin="5,3" FontFamily="Consolas"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SecondMatrixM11}" HorizontalAlignment="Center" Margin="5,3" FontFamily="Consolas"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding SecondMatrixM12}" HorizontalAlignment="Center" Margin="5,3" FontFamily="Consolas"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding SecondMatrixM20}" HorizontalAlignment="Center" Margin="5,3" FontFamily="Consolas"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SecondMatrixM21}" HorizontalAlignment="Center" Margin="5,3" FontFamily="Consolas"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding SecondMatrixM22}" HorizontalAlignment="Center" Margin="5,3" FontFamily="Consolas"/>
                                    </Grid>
                                </Border>

                                <!-- 第二组偏移向量 -->
                                <TextBlock Text="偏移向量" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                                <Border Background="#F5F5F5" CornerRadius="4" Padding="10" Margin="0,0,0,15">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Margin="10,0" FontFamily="Consolas">
                                            <Run Text="X: "/><Run Text="{Binding SecondOffsetX, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Margin="10,0" FontFamily="Consolas">
                                            <Run Text="Y: "/><Run Text="{Binding SecondOffsetY, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Margin="10,0" FontFamily="Consolas">
                                            <Run Text="Z: "/><Run Text="{Binding SecondOffsetZ, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- 第二组残差统计 -->
                                <TextBlock Text="残差统计" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                                <Border Background="#F5F5F5" CornerRadius="4" Padding="10" Margin="0,0,0,15">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="残差均值：" Margin="0,2"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,2">
                                            <Run Text="{Binding SecondCalculationResult.Quality.ResidualMean, Mode=OneWay, StringFormat={}{0:F4}}"/>
                                            <Run Text=" nT"/>
                                        </TextBlock>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="残差标准差：" Margin="0,2"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,2">
                                            <Run Text="{Binding SecondCalculationResult.Quality.ResidualStd, Mode=OneWay, StringFormat={}{0:F4}}"/>
                                            <Run Text=" nT"/>
                                        </TextBlock>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="最大残差：" Margin="0,2"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,2">
                                            <Run Text="{Binding SecondCalculationResult.Quality.MaxResidual, Mode=OneWay, StringFormat={}{0:F4}}"/>
                                            <Run Text=" nT"/>
                                        </TextBlock>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="球面覆盖度：" Margin="0,2"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,2">
                                            <Run Text="{Binding SecondCalculationResult.Quality.SphericityCoverage, Mode=OneWay, StringFormat={}{0:P1}}"/>
                                        </TextBlock>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="样本数量：" Margin="0,2"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SecondCalculationResult.Quality.SampleCount, Mode=OneWay}" Margin="0,2"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ==================== Step 4: 保存配置 ==================== -->
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="4">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
                    <TextBlock Text="保存校正配置" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Text="为本次校正结果命名并保存。" Foreground="Gray" Margin="0,0,0,20"/>

                    <TextBlock Text="配置名称" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,15" Padding="5,4"/>

                    <TextBlock Text="备注（可选）" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding ProfileNotes, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" Height="80" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,15" Padding="5,4"/>

                    <CheckBox Content="设为当前传感器的默认校正配置"
                              IsChecked="{Binding SetAsDefault}" Margin="0,0,0,15"/>

                    <Button Content="保存配置" Padding="20,8" HorizontalAlignment="Left"
                            Command="{Binding SaveProfileCommand}" Margin="0,0,0,10"/>

                    <TextBlock Text="{Binding SaveStatus}" FontSize="13" Foreground="#2E7D32" Margin="0,0,0,10"/>

                    <!-- 已保存配置管理 -->
                    <TextBlock Text="已保存的校正配置" FontSize="16" FontWeight="Bold" Margin="0,20,0,8"/>
                    <Border Background="#F5F5F5" CornerRadius="4" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <ListBox ItemsSource="{Binding SavedProfiles}" SelectedItem="{Binding SelectedSavedProfile}"
                                     DisplayMemberPath="Name" Height="120" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="加载选中" Command="{Binding LoadSelectedProfileCommand}" Padding="10,4" Margin="0,0,5,0"/>
                                <Button Content="删除选中" Command="{Binding DeleteSavedProfileCommand}"
                                        CommandParameter="{Binding SelectedSavedProfile}" Padding="10,4" Margin="0,0,5,0"/>
                                <Button Content="刷新列表" Command="{Binding LoadSavedProfilesCommand}" Padding="10,4"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
