<Window x:Class="MagnetometerSystem.App.Views.Dialogs.CommandEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="640" Height="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 名称 -->
        <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="命令名:" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" x:Name="NameBox" Padding="4"/>
        </Grid>

        <!-- 描述 -->
        <Grid Grid.Row="1" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="描述:" VerticalAlignment="Top" Margin="0,4,0,0"/>
            <TextBox Grid.Column="1" x:Name="DescriptionBox"
                     Padding="4" Height="44" TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"/>
        </Grid>

        <!-- 模板 -->
        <Grid Grid.Row="2" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="模板:" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" x:Name="TemplateBox"
                     Padding="4" FontFamily="Consolas"
                     ToolTip="占位符 {key} 会被参数值替换。例如：SET_RATE {rate}"/>
        </Grid>

        <!-- 选项 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="80,0,0,8">
            <CheckBox x:Name="IsHexCheckBox" Content="Hex 模式" Margin="0,0,16,0"/>
            <CheckBox x:Name="AppendNewlineCheckBox" Content="ASCII 自动追加 \r\n"/>
        </StackPanel>

        <!-- 参数列表 -->
        <GroupBox Grid.Row="4" Header="参数（可添加任意个数）" Padding="6">
            <DockPanel>
                <Button DockPanel.Dock="Top" Content="+ 添加参数" HorizontalAlignment="Left"
                        Padding="10,4" Margin="0,0,0,6" Click="AddParameter_Click"/>
                <DataGrid ItemsSource="{Binding Parameters}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowHeight="28">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="100"/>
                        <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="80"/>
                        <DataGridComboBoxColumn Header="类型"
                                                SelectedItemBinding="{Binding Type}"
                                                Width="80">
                            <DataGridComboBoxColumn.ElementStyle>
                                <Style TargetType="ComboBox">
                                    <Setter Property="ItemsSource"
                                            Value="{Binding DataContext.ParameterTypes, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                </Style>
                            </DataGridComboBoxColumn.ElementStyle>
                            <DataGridComboBoxColumn.EditingElementStyle>
                                <Style TargetType="ComboBox">
                                    <Setter Property="ItemsSource"
                                            Value="{Binding DataContext.ParameterTypes, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                </Style>
                            </DataGridComboBoxColumn.EditingElementStyle>
                        </DataGridComboBoxColumn>
                        <DataGridTextColumn Header="默认值" Binding="{Binding DefaultValue}" Width="80"/>
                        <DataGridTextColumn Header="单位" Binding="{Binding Unit}" Width="60"/>
                        <DataGridTextColumn Header="Min" Binding="{Binding Min}" Width="60"/>
                        <DataGridTextColumn Header="Max" Binding="{Binding Max}" Width="60"/>
                        <DataGridTemplateColumn Header="" Width="40">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="✕" Padding="4,0" Foreground="Red"
                                            Click="RemoveParameter_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </GroupBox>

        <!-- 按钮 -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="确定" Width="80" IsDefault="True" Click="Ok_Click" Margin="0,0,8,0"/>
            <Button Content="取消" Width="80" IsCancel="True" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
