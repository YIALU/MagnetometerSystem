<Window x:Class="MagnetometerSystem.App.Views.Dialogs.CommandEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="780" Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 名称 -->
        <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="命令名:" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" x:Name="NameBox" Padding="4"/>
        </Grid>

        <!-- 描述 -->
        <Grid Grid.Row="1" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="描述:" VerticalAlignment="Top" Margin="0,4,0,0"/>
            <TextBox Grid.Column="1" x:Name="DescriptionBox"
                     Padding="4" Height="40" TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"/>
        </Grid>

        <!-- 编码模式 -->
        <Grid Grid.Row="2" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="编码:" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <RadioButton x:Name="AsciiRadio" Content="ASCII 模板"
                             GroupName="Mode" Margin="0,0,16,0"
                             Checked="Mode_Checked"/>
                <RadioButton x:Name="BinaryRadio" Content="二进制帧"
                             GroupName="Mode"
                             Checked="Mode_Checked"/>
            </StackPanel>
        </Grid>

        <!-- 模式专属面板 -->
        <Grid Grid.Row="3">
            <!-- ASCII 面板 -->
            <StackPanel x:Name="AsciiPanel">
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="模板:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="TemplateBox"
                             Padding="4" FontFamily="Consolas"
                             ToolTip="占位符 {key} 会被参数值替换。例：SET_RATE {rate}"/>
                </Grid>
                <CheckBox x:Name="AppendNewlineCheckBox" Content="自动追加 \r\n"
                          Margin="80,0,0,0"/>
            </StackPanel>

            <!-- BinaryFrame 面板 -->
            <StackPanel x:Name="BinaryPanel" Visibility="Collapsed">
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="帧头(hex):" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="FrameHeaderBox" Padding="4"
                             FontFamily="Consolas"
                             ToolTip="可选，留空表示无帧头。例：AA 55"/>
                    <TextBlock Grid.Column="2" Text="帧尾(hex):" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <TextBox Grid.Column="3" x:Name="FrameTailBox" Padding="4"
                             FontFamily="Consolas"
                             ToolTip="可选，留空表示无帧尾。例：55 AA"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="校验:" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" x:Name="ChecksumBox"
                              ItemsSource="{Binding ChecksumKinds}" Padding="4"/>
                    <TextBlock Grid.Column="2" Foreground="Gray" VerticalAlignment="Center" Margin="8,0,0,0"
                               Text="校验范围：仅数据帧（不含帧头帧尾）"/>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- 参数列表 -->
        <GroupBox Grid.Row="4" Header="参数（可添加任意个数；二进制帧按列出顺序拼接）" Padding="6" Margin="0,8,0,0">
            <DockPanel>
                <Button DockPanel.Dock="Top" Content="+ 添加参数" HorizontalAlignment="Left"
                        Padding="10,4" Margin="0,0,0,6" Click="AddParameter_Click"/>
                <DataGrid ItemsSource="{Binding Parameters}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowHeight="28">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="100"/>
                        <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="70"/>
                        <DataGridComboBoxColumn Header="类型"
                                                SelectedItemBinding="{Binding Type}"
                                                Width="90">
                            <DataGridComboBoxColumn.ElementStyle>
                                <Style TargetType="ComboBox">
                                    <Setter Property="ItemsSource"
                                            Value="{Binding DataContext.ParameterTypes, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                </Style>
                            </DataGridComboBoxColumn.ElementStyle>
                            <DataGridComboBoxColumn.EditingElementStyle>
                                <Style TargetType="ComboBox">
                                    <Setter Property="ItemsSource"
                                            Value="{Binding DataContext.ParameterTypes, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                </Style>
                            </DataGridComboBoxColumn.EditingElementStyle>
                        </DataGridComboBoxColumn>
                        <DataGridComboBoxColumn Header="字节序"
                                                SelectedItemBinding="{Binding Endian}"
                                                Width="80">
                            <DataGridComboBoxColumn.ElementStyle>
                                <Style TargetType="ComboBox">
                                    <Setter Property="ItemsSource"
                                            Value="{Binding DataContext.Endians, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                </Style>
                            </DataGridComboBoxColumn.ElementStyle>
                            <DataGridComboBoxColumn.EditingElementStyle>
                                <Style TargetType="ComboBox">
                                    <Setter Property="ItemsSource"
                                            Value="{Binding DataContext.Endians, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                </Style>
                            </DataGridComboBoxColumn.EditingElementStyle>
                        </DataGridComboBoxColumn>
                        <DataGridTextColumn Header="默认值" Binding="{Binding DefaultValue}" Width="80"/>
                        <DataGridTextColumn Header="单位" Binding="{Binding Unit}" Width="50"/>
                        <DataGridTextColumn Header="Min" Binding="{Binding Min}" Width="55"/>
                        <DataGridTextColumn Header="Max" Binding="{Binding Max}" Width="55"/>
                        <DataGridTextColumn Header="字节长" Binding="{Binding ByteLength}" Width="55"
                                            ToolTipService.ToolTip="仅 HexBytes 类型用于长度校验"/>
                        <DataGridTemplateColumn Header="" Width="40">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="✕" Padding="4,0" Foreground="Red"
                                            Click="RemoveParameter_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </GroupBox>

        <!-- 按钮 -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="确定" Width="80" IsDefault="True" Click="Ok_Click" Margin="0,0,8,0"/>
            <Button Content="取消" Width="80" IsCancel="True" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
