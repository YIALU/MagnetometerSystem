<Window x:Class="MagnetometerSystem.App.Views.Dialogs.SessionPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="从已采集会话导入"
        Width="780" Height="480"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="0,0,0,8" TextWrapping="Wrap"
                   Text="选择一个已采集会话作为正交度校准的输入数据。会话中的通道值会按 X/Y/Z 顺序加载（双三轴取前 6 通道）。"/>

        <DataGrid Grid.Row="1" x:Name="SessionsGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  MouseDoubleClick="Grid_DoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="开始时间" Binding="{Binding StartedAt, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="150"/>
                <DataGridTextColumn Header="传感器" Binding="{Binding SensorType}" Width="130"/>
                <DataGridTextColumn Header="通道" Binding="{Binding ChannelCount}" Width="60"/>
                <DataGridTextColumn Header="样本数" Binding="{Binding TotalReadings}" Width="80"/>
                <DataGridTextColumn Header="备注" Binding="{Binding Notes}" Width="160"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="#666" Margin="0,0,12,0"/>
            <Button Content="确定" Width="80" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click"/>
            <Button Content="取消" Width="80" IsCancel="True" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
