<Window x:Class="MagnetometerSystem.App.Views.Dialogs.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于"
        Width="440" Height="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="磁力仪数据采集与分析系统"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" x:Name="VersionText"
                   FontFamily="Consolas" FontSize="13" Foreground="#444"
                   Margin="0,0,0,12"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="版本号:" Foreground="#666" Margin="0,2"/>
            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="VersionNumberText" FontFamily="Consolas" Margin="0,2"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Commit:" Foreground="#666" Margin="0,2"/>
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="CommitText" FontFamily="Consolas" Margin="0,2"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="构建时间:" Foreground="#666" Margin="0,2"/>
            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="BuildTimeText" FontFamily="Consolas" Margin="0,2"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="框架:" Foreground="#666" Margin="0,2"/>
            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="RuntimeText" FontFamily="Consolas" Margin="0,2"/>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="复制版本信息" Padding="10,4" Margin="0,0,8,0" Click="Copy_Click"/>
            <Button Content="关闭" Width="80" IsDefault="True" IsCancel="True" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
