<UserControl x:Class="MagnetometerSystem.App.Views.ConnectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:models="clr-namespace:MagnetometerSystem.Core.Models;assembly=MagnetometerSystem.Core"
             xmlns:protocol="clr-namespace:MagnetometerSystem.Core.Protocol;assembly=MagnetometerSystem.Core"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="900">
    <UserControl.Resources>
        <ObjectDataProvider x:Key="FieldDataTypeValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:FieldDataType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="ChecksumAlgorithmValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:ChecksumAlgorithm"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="Crc16VariantValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="protocol:Crc16Variant"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="15">
            <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 传感器配置区 -->
        <GroupBox Grid.Row="0" Header="传感器配置" Margin="0,0,0,8" Padding="10">
            <WrapPanel>
                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="传感器类型" Margin="0,0,0,3"/>
                    <ComboBox Width="160" ItemsSource="{Binding SensorTypes}"
                              SelectedItem="{Binding SelectedSensorType}"/>
                </StackPanel>
                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="采样率 (Hz)" Margin="0,0,0,3"/>
                    <ComboBox Width="100" ItemsSource="{Binding PresetSampleRates}"
                              SelectedItem="{Binding SampleRate}"
                              IsEditable="True"
                              Text="{Binding SampleRate, UpdateSourceTrigger=LostFocus}"/>
                </StackPanel>
            </WrapPanel>
        </GroupBox>

        <!-- 连接参数区 -->
        <GroupBox Grid.Row="1" Header="连接参数" Margin="0,0,0,8" Padding="10">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="连接方式" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox Width="100" ItemsSource="{Binding ConnectionTypes}"
                              SelectedItem="{Binding SelectedConnectionType}"/>
                </StackPanel>

                <!-- 串口参数 -->
                <WrapPanel Margin="0,0,0,5">
                    <WrapPanel.Style>
                        <Style TargetType="WrapPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedConnectionType}" Value="Serial">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </WrapPanel.Style>
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="串口" Margin="0,0,0,3"/>
                        <StackPanel Orientation="Horizontal">
                            <ComboBox Width="90" ItemsSource="{Binding AvailablePorts}"
                                      SelectedItem="{Binding SelectedPort}"/>
                            <Button Content="刷新" Margin="5,0,0,0" Padding="8,2"
                                    Command="{Binding RefreshPortsCommand}"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="波特率" Margin="0,0,0,3"/>
                        <ComboBox Width="100" ItemsSource="{Binding BaudRates}"
                                  SelectedItem="{Binding BaudRate}" IsEditable="True"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="数据位" Margin="0,0,0,3"/>
                        <ComboBox Width="60" ItemsSource="{Binding DataBitsOptions}"
                                  SelectedItem="{Binding DataBits}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="校验位" Margin="0,0,0,3"/>
                        <ComboBox Width="80" ItemsSource="{Binding Parities}"
                                  SelectedItem="{Binding Parity}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="停止位" Margin="0,0,0,3"/>
                        <ComboBox Width="60" ItemsSource="{Binding StopBitsOptions}"
                                  SelectedItem="{Binding StopBits}"/>
                    </StackPanel>
                </WrapPanel>

                <!-- TCP 参数 -->
                <WrapPanel Margin="0,0,0,5">
                    <WrapPanel.Style>
                        <Style TargetType="WrapPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedConnectionType}" Value="Tcp">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </WrapPanel.Style>
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="IP 地址" Margin="0,0,0,3"/>
                        <TextBox Width="150" Text="{Binding IpAddress, UpdateSourceTrigger=LostFocus}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="端口" Margin="0,0,0,3"/>
                        <TextBox Width="80" Text="{Binding Port, UpdateSourceTrigger=LostFocus}"/>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </GroupBox>

        <!-- 协议配置区 -->
        <GroupBox Grid.Row="2" Header="协议配置" Margin="0,0,0,8" Padding="10">
            <StackPanel>
                <!-- 预设/加载 -->
                <WrapPanel Margin="0,0,0,8">
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="预设协议" Margin="0,0,0,3"/>
                        <StackPanel Orientation="Horizontal">
                            <ComboBox Width="200" ItemsSource="{Binding SavedProtocols}"
                                      SelectedItem="{Binding SelectedSavedProtocol}"
                                      DisplayMemberPath="Name"/>
                            <Button Content="加载" Margin="5,0,0,0" Padding="8,2"
                                    Command="{Binding LoadSelectedProtocolCommand}"/>
                            <Button Content="保存当前" Margin="5,0,0,0" Padding="8,2"
                                    Command="{Binding SaveProtocolCommand}"/>
                            <Button Content="导入" Margin="10,0,0,0" Padding="8,2"
                                    Command="{Binding ImportProtocolCommand}"/>
                            <Button Content="导出" Margin="5,0,0,0" Padding="8,2"
                                    Command="{Binding ExportProtocolCommand}"/>
                            <TextBlock Text=" ?" FontWeight="Bold" FontSize="14" Foreground="#0078D4"
                                       VerticalAlignment="Center" Margin="8,0,0,0" Cursor="Help">
                                <TextBlock.ToolTip>
                                    <ToolTip MaxWidth="350">
                                        <TextBlock TextWrapping="Wrap" FontSize="12">
配置文件格式: JSON
主要字段:
  Name - 协议名称
  Category - Ascii 或 Binary
  AsciiDelimiter - ASCII分隔符(如 ",")
  FrameHeader/FrameTail - 帧头帧尾(Hex)
  Checksum - None/Xor/Sum/Crc16
  FieldMappings - 字段映射数组:
    Name, ChannelIndex, ByteOffset,
    DataType, Scale, Offset, BigEndian
                                        </TextBlock>
                                    </ToolTip>
                                </TextBlock.ToolTip>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </WrapPanel>

                <!-- 基本参数 -->
                <WrapPanel Margin="0,0,0,8">
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="协议名称" Margin="0,0,0,3"/>
                        <TextBox Width="180" Text="{Binding ProtocolConfig.Name, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="协议类型" Margin="0,0,0,3"/>
                        <ComboBox Width="100" ItemsSource="{Binding ProtocolCategories}"
                                  SelectedItem="{Binding ProtocolConfig.Category}"/>
                    </StackPanel>
                </WrapPanel>

                <!-- ASCII 参数 -->
                <WrapPanel Margin="0,0,0,8">
                    <WrapPanel.Style>
                        <Style TargetType="WrapPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ProtocolConfig.Category}" Value="{x:Static models:ProtocolCategory.Ascii}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </WrapPanel.Style>
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="分隔符" Margin="0,0,0,3"/>
                        <TextBox Width="80" Text="{Binding ProtocolConfig.AsciiDelimiter, UpdateSourceTrigger=LostFocus}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,15,0">
                        <CheckBox Content="首行为表头" Margin="0,5,0,0"
                                  IsChecked="{Binding ProtocolConfig.AsciiHasHeader}"/>
                    </StackPanel>
                </WrapPanel>

                <!-- 二进制参数 — 帧段配置 -->
                <StackPanel Margin="0,0,0,8">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ProtocolConfig.Category}" Value="{x:Static models:ProtocolCategory.Binary}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- 添加段按钮行 -->
                    <WrapPanel Margin="0,0,0,5">
                        <TextBlock Text="添加帧段:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                        <Button Content="+帧头" Padding="6,2" Margin="0,0,4,0"
                                Command="{Binding AddSegmentCommand}" CommandParameter="{x:Static models:SegmentType.Header}"/>
                        <Button Content="+长度" Padding="6,2" Margin="0,0,4,0"
                                Command="{Binding AddSegmentCommand}" CommandParameter="{x:Static models:SegmentType.LengthField}"/>
                        <Button Content="+数据字段" Padding="6,2" Margin="0,0,4,0"
                                Command="{Binding AddSegmentCommand}" CommandParameter="{x:Static models:SegmentType.DataField}"/>
                        <Button Content="+校验" Padding="6,2" Margin="0,0,4,0"
                                Command="{Binding AddSegmentCommand}" CommandParameter="{x:Static models:SegmentType.Checksum}"/>
                        <Button Content="+帧尾" Padding="6,2" Margin="0,0,4,0"
                                Command="{Binding AddSegmentCommand}" CommandParameter="{x:Static models:SegmentType.Tail}"/>
                        <Button Content="+填充" Padding="6,2" Margin="0,0,4,0"
                                Command="{Binding AddSegmentCommand}" CommandParameter="{x:Static models:SegmentType.Padding}"/>
                    </WrapPanel>

                    <!-- 帧段列表 -->
                    <ListView ItemsSource="{Binding ProtocolSegments}" MaxHeight="280"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              BorderThickness="1" BorderBrush="#CCC">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="类型" Width="65">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding Type}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Type}" Value="{x:Static models:SegmentType.Header}">
                                                                <Setter Property="Text" Value="帧头"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="{x:Static models:SegmentType.LengthField}">
                                                                <Setter Property="Text" Value="长度"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="{x:Static models:SegmentType.DataField}">
                                                                <Setter Property="Text" Value="数据"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="{x:Static models:SegmentType.Checksum}">
                                                                <Setter Property="Text" Value="校验"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="{x:Static models:SegmentType.Tail}">
                                                                <Setter Property="Text" Value="帧尾"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="{x:Static models:SegmentType.Padding}">
                                                                <Setter Property="Text" Value="填充"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="名称" Width="70">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Name, UpdateSourceTrigger=LostFocus}" Width="60" FontSize="11" BorderThickness="0"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="字节" Width="50">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <!-- DataField: 只读（由 DataType 自动计算） -->
                                                <TextBlock Text="{Binding ByteCount}" FontSize="11" HorizontalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Type}" Value="{x:Static models:SegmentType.DataField}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <!-- 非 DataField: 可编辑 -->
                                                <TextBox Text="{Binding ByteCount, UpdateSourceTrigger=LostFocus}"
                                                         Width="35" FontSize="11" HorizontalAlignment="Center" BorderThickness="0">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Type}" Value="{x:Static models:SegmentType.DataField}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>
                                            </Grid>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="详情" Width="280">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <!-- Header/Tail/Padding: Hex 值 -->
                                                <TextBox Text="{Binding FixedHexValue, UpdateSourceTrigger=LostFocus}"
                                                         Width="150" FontSize="11" FontFamily="Consolas" CharacterCasing="Upper"
                                                         Margin="0,0,5,0" ToolTip="输入十六进制值，自动按字节数截断/补零">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Type}" Value="{x:Static models:SegmentType.Header}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="{x:Static models:SegmentType.Tail}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="{x:Static models:SegmentType.Padding}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>

                                                <!-- DataField: 数据类型 + 大端序 + 通道 + 缩放 + 偏移 -->
                                                <StackPanel Orientation="Horizontal">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Type}" Value="{x:Static models:SegmentType.DataField}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <ComboBox ItemsSource="{Binding Source={StaticResource FieldDataTypeValues}}"
                                                              SelectedItem="{Binding DataType}" Width="60" FontSize="11" Margin="0,0,3,0"/>
                                                    <CheckBox Content="大端" IsChecked="{Binding BigEndian}" VerticalAlignment="Center" FontSize="11" Margin="0,0,3,0"/>
                                                    <TextBlock Text="CH" VerticalAlignment="Center" FontSize="11"/>
                                                    <TextBox Text="{Binding ChannelIndex, UpdateSourceTrigger=LostFocus}" Width="25" FontSize="11" Margin="0,0,3,0"/>
                                                    <TextBlock Text="x" VerticalAlignment="Center" FontSize="11"/>
                                                    <TextBox Text="{Binding Scale, UpdateSourceTrigger=LostFocus}" Width="35" FontSize="11" Margin="0,0,2,0"/>
                                                    <TextBlock Text="+" VerticalAlignment="Center" FontSize="11"/>
                                                    <TextBox Text="{Binding Offset, UpdateSourceTrigger=LostFocus}" Width="35" FontSize="11"/>
                                                </StackPanel>

                                                <!-- LengthField: 大端序 -->
                                                <CheckBox Content="大端序" IsChecked="{Binding LengthBigEndian}" VerticalAlignment="Center" FontSize="11">
                                                    <CheckBox.Style>
                                                        <Style TargetType="CheckBox">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Type}" Value="{x:Static models:SegmentType.LengthField}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </CheckBox.Style>
                                                </CheckBox>

                                                <!-- Checksum: 算法选择 -->
                                                <ComboBox ItemsSource="{Binding Source={StaticResource ChecksumAlgorithmValues}}"
                                                          SelectedItem="{Binding ChecksumAlgorithm}" Width="65" FontSize="11">
                                                    <ComboBox.Style>
                                                        <Style TargetType="ComboBox">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Type}" Value="{x:Static models:SegmentType.Checksum}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ComboBox.Style>
                                                </ComboBox>

                                                <!-- Checksum: CRC16 变体选择（仅 CRC16 算法时显示） -->
                                                <ComboBox ItemsSource="{Binding Source={StaticResource Crc16VariantValues}}"
                                                          SelectedItem="{Binding Crc16Variant}" Width="90" FontSize="11"
                                                          Margin="4,0,0,0" ToolTip="CRC-16 变体，必须与设备端一致">
                                                    <ComboBox.Style>
                                                        <Style TargetType="ComboBox">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding Type}" Value="{x:Static models:SegmentType.Checksum}"/>
                                                                        <Condition Binding="{Binding ChecksumAlgorithm}" Value="{x:Static models:ChecksumAlgorithm.CRC16}"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ComboBox.Style>
                                                </ComboBox>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="操作" Width="85">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="^" Width="22" FontSize="10" Padding="0"
                                                        Command="{Binding DataContext.MoveSegmentUpCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="v" Width="22" FontSize="10" Padding="0" Margin="2,0,0,0"
                                                        Command="{Binding DataContext.MoveSegmentDownCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="X" Width="22" FontSize="10" Padding="0" Margin="2,0,0,0" Foreground="Red"
                                                        Command="{Binding DataContext.RemoveSegmentCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- 总帧长度 -->
                    <TextBlock Margin="0,4,0,0" FontSize="12">
                        <Run Text="总帧长: "/>
                        <Run Text="{Binding TotalFrameLength, Mode=OneWay}"/>
                        <Run Text=" 字节"/>
                    </TextBlock>
                </StackPanel>

                <!-- 字段映射（仅 ASCII 模式） -->
                <Expander Header="字段映射 (ASCII)" Margin="0,0,0,0" IsExpanded="False">
                    <Expander.Style>
                        <Style TargetType="Expander">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ProtocolConfig.Category}" Value="{x:Static models:ProtocolCategory.Ascii}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Expander.Style>
                    <StackPanel Margin="0,5,0,0">
                        <DataGrid ItemsSource="{Binding ProtocolConfig.FieldMappings}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  Height="150"
                                  FontSize="12">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="60"/>
                                <DataGridTextColumn Header="通道" Binding="{Binding ChannelIndex}" Width="50"/>
                                <DataGridTextColumn Header="偏移" Binding="{Binding ByteOffset}" Width="50"/>
                                <DataGridComboBoxColumn Header="数据类型" Width="80"
                                    SelectedItemBinding="{Binding DataType}"
                                    ItemsSource="{Binding Source={StaticResource FieldDataTypeValues}}"/>
                                <DataGridTextColumn Header="缩放" Binding="{Binding Scale}" Width="60"/>
                                <DataGridTextColumn Header="偏移量" Binding="{Binding Offset}" Width="60"/>
                                <DataGridCheckBoxColumn Header="大端序" Binding="{Binding BigEndian}" Width="55"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <Button Content="添加字段" Padding="8,3" Command="{Binding AddFieldMappingCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </GroupBox>

        <!-- 操作按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Padding="20,8" Command="{Binding ConnectCommand}">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Content" Value="开始"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                <Setter Property="Content" Value="停止"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="15,0,0,0"
                       FontSize="13">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="Gray"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                <Setter Property="Foreground" Value="Green"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <CheckBox Content="显示 Hex" VerticalAlignment="Center" Margin="20,0,0,0"
                      IsChecked="{Binding ShowHex}"/>
            <Button Content="清空" Padding="8,4" Margin="15,0,0,0"
                    Command="{Binding ClearRawDataCommand}"/>
        </StackPanel>

        <!-- 原始数据显示区 -->
        <GroupBox Grid.Row="4" Header="原始数据" Padding="5">
            <ListBox ItemsSource="{Binding RawDataLines}" FontFamily="Consolas" FontSize="12"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="NoWrap"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>
        </Grid>
    </ScrollViewer>
</UserControl>
