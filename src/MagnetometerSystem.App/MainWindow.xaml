<Window x:Class="MagnetometerSystem.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MagnetometerSystem.App"
        xmlns:views="clr-namespace:MagnetometerSystem.App.Views"
        xmlns:vm="clr-namespace:MagnetometerSystem.App.ViewModels"
        mc:Ignorable="d"
        Title="磁力仪数据采集与分析系统" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- 顶部状态栏 -->
        <StatusBar DockPanel.Dock="Bottom" Height="28">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Margin="0,0,5,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="Gray"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ConnectionVM.IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="Green"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ConnectionStatus}"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock>
                    <Run Text="传感器: "/>
                    <Run Text="{Binding SensorInfo, Mode=OneWay}"/>
                </TextBlock>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock>
                    <Run Text="采样率: "/>
                    <Run Text="{Binding SampleRateInfo, Mode=OneWay}"/>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>

        <!-- 左侧导航栏 -->
        <Border DockPanel.Dock="Left" Width="160" Background="#F0F0F0" BorderBrush="#D0D0D0" BorderThickness="0,0,1,0">
            <StackPanel Margin="5">
                <TextBlock Text="功能导航" FontWeight="Bold" FontSize="14" Margin="5,10,5,15" HorizontalAlignment="Center"/>
                <Button Content="设备连接" Margin="3" Padding="8,6" HorizontalContentAlignment="Left"/>
                <Button Content="实时采集" Margin="3" Padding="8,6" HorizontalContentAlignment="Left" IsEnabled="False"/>
                <Button Content="历史回放" Margin="3" Padding="8,6" HorizontalContentAlignment="Left" IsEnabled="False"/>
                <Button Content="正交度校正" Margin="3" Padding="8,6" HorizontalContentAlignment="Left" IsEnabled="False"/>
                <Button Content="传感器校准" Margin="3" Padding="8,6" HorizontalContentAlignment="Left" IsEnabled="False"/>
                <Button Content="系统设置" Margin="3" Padding="8,6" HorizontalContentAlignment="Left" IsEnabled="False"/>
            </StackPanel>
        </Border>

        <!-- 主内容区 -->
        <ContentControl Content="{Binding CurrentView}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:ConnectionViewModel}">
                    <views:ConnectionView/>
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </DockPanel>
</Window>
