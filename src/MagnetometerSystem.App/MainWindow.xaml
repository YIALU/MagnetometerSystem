<Window x:Class="MagnetometerSystem.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MagnetometerSystem.App"
        xmlns:views="clr-namespace:MagnetometerSystem.App.Views"
        xmlns:vm="clr-namespace:MagnetometerSystem.App.ViewModels"
        xmlns:converters="clr-namespace:MagnetometerSystem.App.Converters"
        mc:Ignorable="d"
        Title="磁力仪数据采集与分析系统" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    </Window.Resources>
    <Grid>
    <DockPanel>
        <!-- 底部状态栏 -->
        <StatusBar DockPanel.Dock="Bottom" Height="28">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Margin="0,0,5,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="Gray"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ConnectionVM.IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="Green"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ConnectionStatus}"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock>
                    <Run Text="传感器: "/>
                    <Run Text="{Binding SensorInfo, Mode=OneWay}"/>
                </TextBlock>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock>
                    <Run Text="采样率: "/>
                    <Run Text="{Binding SampleRateInfo, Mode=OneWay}"/>
                </TextBlock>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock>
                    <Run Text="数据点: "/>
                    <Run Text="{Binding DataCount, Mode=OneWay}"/>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>

        <!-- 左侧导航栏 -->
        <Border DockPanel.Dock="Left" Width="160" Background="#F0F0F0" BorderBrush="#D0D0D0" BorderThickness="0,0,1,0">
            <StackPanel Margin="5">
                <TextBlock Text="功能导航" FontWeight="Bold" FontSize="14" Margin="5,10,5,15" HorizontalAlignment="Center"/>
                <Button Content="设备连接" Margin="3" Padding="8,6" HorizontalContentAlignment="Left"
                        Command="{Binding NavigateToConnectionCommand}"/>
                <Button Content="实时采集" Margin="3" Padding="8,6" HorizontalContentAlignment="Left"
                        Command="{Binding NavigateToRealtimeChartCommand}"/>
                <Button Content="数据管理" Margin="3" Padding="8,6" HorizontalContentAlignment="Left"
                        Command="{Binding NavigateToSessionListCommand}"/>
                <Button Content="历史回放" Margin="3" Padding="8,6" HorizontalContentAlignment="Left"
                        Command="{Binding NavigateToHistoryPlaybackCommand}"/>
                <Button Content="正交度校正" Margin="3" Padding="8,6" HorizontalContentAlignment="Left"
                        Command="{Binding NavigateToOrthogonalityCalibrationCommand}"/>
                <Button Content="传感器校准" Margin="3" Padding="8,6" HorizontalContentAlignment="Left"
                        Command="{Binding NavigateToSensorCalibrationCommand}"/>
                <Button Content="系统设置" Margin="3" Padding="8,6" HorizontalContentAlignment="Left"
                        Command="{Binding NavigateToSettingsCommand}"/>
                <Button Content="设备命令" Margin="3" Padding="8,6" HorizontalContentAlignment="Left"
                        Command="{Binding NavigateToDeviceCommandCommand}"/>
            </StackPanel>
        </Border>

        <!-- 主内容区 -->
        <ContentControl Content="{Binding CurrentView}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:ConnectionViewModel}">
                    <views:ConnectionView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:RealtimeChartViewModel}">
                    <views:RealtimeChartView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:SessionListViewModel}">
                    <views:SessionListView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:HistoryPlaybackViewModel}">
                    <views:HistoryPlaybackView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:OrthogonalityCalibrationViewModel}">
                    <views:OrthogonalityCalibrationView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:SensorCalibrationViewModel}">
                    <views:SensorCalibrationView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                    <views:SettingsView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:DeviceCommandViewModel}">
                    <views:DeviceCommandView/>
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </DockPanel>

    <!-- 初始化加载遮罩 -->
    <Grid Visibility="{Binding IsInitialized, Converter={StaticResource InverseBoolToVisibilityConverter}}"
          Background="#88000000" Panel.ZIndex="100">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="正在初始化..." Foreground="White" FontSize="16" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
    </Grid>
</Window>
